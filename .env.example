# ============================================================================
# Freesail Agent — Environment Configuration
# Copy this file to agent/.env and fill in the values.
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Provider — choose 'gemini' (default), 'openai', or 'claude'
# ----------------------------------------------------------------------------
#LM_PROVIDER=gemini

# Google Gemini (required when LLM_PROVIDER=gemini)
#GOOGLE_API_KEY=your-google-api-key-here
#GEMINI_MODEL=gemini-2.5-pro

# OpenAI (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# Temperature (applies to all providers, default: 0.7)
# LLM_TEMPERATURE=0.7

# Anthropic Claude (required when LLM_PROVIDER=claude)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ----------------------------------------------------------------------------
# Custom prompt (optional — injected into every session prompt at runtime)
# ----------------------------------------------------------------------------
# CUSTOM_PROMPT_FILE=customprompt.txt   # relative to project root (same dir as .env), or absolute path

# ----------------------------------------------------------------------------
# Ports (optional — these are the defaults)
# ----------------------------------------------------------------------------
# AGENT_PORT=3002
# MCP_PORT=3000
# GATEWAY_PORT=3001

# ----------------------------------------------------------------------------
# Gateway logging (set in example/.env, not here — listed for reference)
# ----------------------------------------------------------------------------
# LOG_LEVEL=info        # fatal | error | warn | info | debug (default: info)
# LOG_FILE= .freesail_logs            # e.g. logs/gateway.log
# LOG_FILTER=           # space-separated overrides, e.g.:
# session.agent-surface:debug   — agent-created surfaces (no __ prefix)
# LOG_FILTER=session.client-surface:warn   — client-managed surfaces (__ prefix)
# mcp:debug express:warn
