{
  "name": "freesail-quickstarter-agent",
  "version": "0.4.6",
  "private": true,
  "description": "Example LangChain agent for Freesail — supports Gemini and OpenAI",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx watch --env-file=../.env --inspect=9230 src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@freesail/agent-runtime": "*",
    "@freesail/logger": "*",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/anthropic": "^1.3.6",
    "@langchain/openai": "^1.2.13",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.0"
  }
}
